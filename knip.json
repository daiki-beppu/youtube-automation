{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [],
      "project": [],
      "ignoreDependencies": ["takt"]
    },
    "packages/cli": {
      "entry": ["src/commands/*/cli.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts", "*/*.ts"]
    },
    "packages/core": {
      "project": ["src/**/*.ts", "test/**/*.ts", "*/*.ts"]
    }
  },
  "ignore": ["extensions/**"],
  "ignoreBinaries": ["compile", "build", "playwright"]
}
