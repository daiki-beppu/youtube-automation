# nix-direnv: dev 環境を .direnv/ にキャッシュし、flake.nix / flake.lock / .envrc が
# 変わらない限り入場時に nix を起動しない。direnv stdlib の use_flake は入場のたびに
# `nix print-dev-env`（flake 評価）を実行するため、dirty worktree では評価コストが
# 毎回壁時計に乗り 7〜80 秒まで変動し得る（issue #2097）
# 並列 run 間の共有 TMPDIR 競合を避ける worktree 分離（issue #2088）。
# nix-direnv は cached dev-env の適用時に TMPDIR を無視リストで除外するため、
# flake.nix shellHook の export は direnv 経路では届かない。direnv 経路は
# ここで export し、nix develop 直接経路は shellHook 側の export が担う
if worktree_tmpdir="$(bash "$PWD/.lefthook/worktree-tmpdir.sh" 2>/dev/null)"; then
  export TMPDIR="$worktree_tmpdir"
  # 並列 worktree 間で Nix のユーザーグローバルキャッシュ（既定 ~/.cache/nix）を共有
  # すると、同一 fingerprint の同時 flake 評価が eval-cache SQLite で競合し
  # 「error (ignored): SQLite database ... is busy」を stderr へ出しつつキャッシュ
  # 書込みを破棄し続ける（issue #2089）。Nix 専用の NIX_CACHE_HOME を worktree 分離
  # TMPDIR 配下へ向け、各 worktree が自分の評価結果だけを参照する。継承値は別
  # worktree の値がシェル経由でリークし得るため尊重せず、常に自 worktree の決定値で
  # 上書きする（XDG_CACHE_HOME には触れないため uv 等の他ツールへ影響しない）
  export NIX_CACHE_HOME="$worktree_tmpdir/nix-cache"
fi

if ! has nix_direnv_version || ! nix_direnv_version 3.1.1; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.1.1/direnvrc" "sha256-p+fzQdrms/hDa7g+soShAybJNo4bN4SIAeSfqNKgD5I="
fi
use flake
