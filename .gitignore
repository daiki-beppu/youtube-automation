# OS
.DS_Store

# Python
__pycache__/
*.pyc
.venv/
.env
.direnv/

# Pytest temp（--basetemp などで生成される一時ディレクトリ）
.tmp_test/

# Nix / tooling caches (do not commit eval / fetcher / tarball caches)
.cache/

# Auth（client_secrets / token は手動配置、git 管理しない）
auth/client_secrets.json
auth/token*.json

# Scheduler (user-specific)
launchd/

# IDE
.vscode/*
!.vscode/extensions.json
.idea/

# Logs
logs/

# Build artifacts
dist/
build/
*.egg-info/
.coverage
.worktrees/

# Terraform
terraform.tfvars
*.tfstate
*.tfstate.*
*.tfplan
.terraform/

# Bench results（perf #131 計測フェーズ）
bench/results/

# Node / Bun (TS rewrite, ADR 0001)
node_modules/
bun.lockb
.bun/
coverage/
packages/*/dist/
*.tsbuildinfo
