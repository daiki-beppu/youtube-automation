# OS
.DS_Store

# Python
__pycache__/
*.pyc
.venv/
.env
.direnv/

# Pytest temp（--basetemp などで生成される一時ディレクトリ）
.tmp_test/

# デバッグ用一時ファイル（chrome-devtools の DOM スナップショット等）
.tmp/

# Nix / tooling caches (do not commit eval / fetcher / tarball caches)
.cache/

# Auth（client_secrets / token は手動配置、git 管理しない）
auth/client_secrets.json
auth/token*.json

# Scheduler (user-specific)
launchd/

# IDE
.vscode/
.idea/

# Logs
logs/

# Build artifacts
dist/
build/
*.egg-info/
.coverage
.worktrees/

# Node / extensions (WXT)
node_modules/
extensions/*/dist/
extensions/*/.wxt/
extensions/*/.output/
extensions/*/test-results/
extensions/*/playwright-report/

# Terraform
terraform.tfvars
*.tfstate
*.tfstate.*
*.tfplan
.terraform/

# Bench results（perf #131 計測フェーズ）
bench/results/
