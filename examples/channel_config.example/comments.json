{
  "comments": {
    "enabled": false,
    "max_replies_per_run": 20,
    "delay_between_replies_sec": 2.0,
    "history_file": "comment_reply_history.json",
    "skip_held_for_review": true,
    "ng_words": ["spam", "http://"],
    "rules": [
      {
        "name": "greeting_ja",
        "keywords": ["こんにちは", "はじめまして"],
        "language": "ja",
        "priority": 10,
        "provider": "codex",
        "scope": "top_level"
      },
      {
        "name": "thanks_en",
        "keywords": ["thank you", "thanks"],
        "language": "en",
        "priority": 5,
        "scope": "any"
      }
    ],
    "generator": {
      "provider": "codex",
      "channel_persona": "Warm YouTube channel host",
      "max_length": 280,
      "fallback_on_error": "skip",
      "requests_per_minute": 30
    }
  }
}
