{
  "permissions": {
    "allow": [
      "Agent",
      "Bash(uv run yt-upload-auto*)",
      "Bash(uv run yt-upload-collection*)",
      "Bash(uv run yt-upload-shorts*)"
    ],
    "deny": [
      "Read(auth/client_secrets.json)",
      "Read(auth/token.json)",
      "Read(.env)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "for f in $CLAUDE_FILE_PATHS; do case \"$f\" in *auth/client_secrets.json|*auth/token.json|*.env) echo \"BLOCKED: $f は AI から直接編集禁止。専用ツール経由で更新してください\" >&2; exit 2;; esac; done"
          }
        ]
      }
    ]
  }
}
