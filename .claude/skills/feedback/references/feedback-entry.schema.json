{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/daiki-beppu/youtube-automation/schemas/feedback-entry.schema.json",
  "title": "Feedback log entry",
  "type": "object",
  "additionalProperties": false,
  "required": ["date", "skill", "category", "summary", "context", "status"],
  "properties": {
    "date": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp for when the feedback was recorded."
    },
    "skill": {
      "type": "string",
      "minLength": 1,
      "description": "Target skill name without the leading slash."
    },
    "category": {
      "type": "string",
      "enum": ["bug", "friction", "idea"]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "One-sentence summary of the feedback."
    },
    "context": {
      "type": "string",
      "minLength": 1,
      "description": "Reproduction context, error excerpt, and expected vs actual behavior with secrets redacted."
    },
    "status": {
      "type": "string",
      "enum": ["recorded", "filed"]
    },
    "issue_url": {
      "type": "string",
      "format": "uri"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "filed"
          }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["issue_url"]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "recorded"
          }
        },
        "required": ["status"]
      },
      "then": {
        "not": {
          "required": ["issue_url"]
        }
      }
    }
  ]
}
