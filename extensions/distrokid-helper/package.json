{
  "name": "distrokid-helper",
  "description": "DistroKid 登録フォーム自動入力 Chrome 拡張 (WXT + React)",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "wxt prepare && tsc --noEmit",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "audit": "fallow audit --root ..",
    "check": "cd .. && ultracite check distrokid-helper",
    "fix": "cd .. && ultracite fix distrokid-helper"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.2.4",
    "@webext-core/messaging": "2.3.0",
    "@wxt-dev/storage": "1.2.8",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "4.2.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@wxt-dev/module-react": "1.2.2",
    "fallow": "3.5.0",
    "jsdom": "26.1.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.73.0",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "ultracite": "7.9.4",
    "vitest": "4.1.8",
    "wxt": "0.20.26"
  }
}
