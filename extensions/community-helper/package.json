{
  "name": "community-helper",
  "version": "0.1.0",
  "private": true,
  "description": "YouTube コミュニティ投稿スケジュール Chrome 拡張 (WXT + React)",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "wxt prepare && tsc --noEmit",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "audit": "fallow audit --root ..",
    "check": "cd .. && ultracite check community-helper",
    "fix": "cd .. && ultracite fix community-helper"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@webext-core/messaging": "3.0.2",
    "@wxt-dev/storage": "1.2.8",
    "@youtube-automation/extensions-shared": "workspace:*",
    "@youtube-automation/ui": "workspace:*",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@wxt-dev/module-react": "1.2.2",
    "fallow": "3.7.1",
    "jsdom": "29.1.1",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "tailwindcss": "4.3.3",
    "typescript": "7.0.2",
    "ultracite": "7.9.4",
    "vitest": "4.1.10",
    "wxt": "0.20.27"
  },
  "packageManager": "pnpm@11.15.1"
}
