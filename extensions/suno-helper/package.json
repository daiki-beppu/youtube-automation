{
  "name": "suno-helper",
  "version": "0.2.5",
  "private": true,
  "description": "/suno が生成した Style/Lyrics を Suno の Advanced タブに順次注入し Generate を連続実行する補助拡張 (WXT + React + TS)。",
  "type": "module",
  "scripts": {
    "postinstall": "wxt prepare",
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "wxt prepare && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "audit": "fallow audit --root ..",
    "check": "cd .. && ultracite check suno-helper shared shared-ui",
    "fix": "cd .. && ultracite fix suno-helper shared shared-ui"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@webext-core/messaging": "3.0.2",
    "@youtube-automation/extensions-shared": "workspace:*",
    "@youtube-automation/ui": "workspace:*",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.3",
    "@types/chrome": "0.2.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@wxt-dev/module-react": "1.2.2",
    "fallow": "3.7.1",
    "jsdom": "29.1.1",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "tailwindcss": "4.3.3",
    "typescript": "7.0.2",
    "ultracite": "7.9.4",
    "vitest": "4.1.10",
    "wxt": "0.20.27"
  },
  "packageManager": "pnpm@11.15.1"
}
