{
  "name": "suno-helper",
  "version": "0.2.5",
  "private": true,
  "description": "/suno が生成した Style/Lyrics を Suno の Advanced タブに順次注入し Generate を連続実行する補助拡張 (WXT + React + TS)。",
  "type": "module",
  "scripts": {
    "postinstall": "wxt prepare",
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "wxt prepare && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "audit": "fallow audit --root ..",
    "check": "cd .. && ultracite check suno-helper shared",
    "fix": "cd .. && ultracite fix suno-helper shared"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "1.3.7",
    "@radix-ui/react-slot": "1.2.4",
    "@webext-core/messaging": "3.0.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "4.2.2",
    "@types/chrome": "0.1.42",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@wxt-dev/module-react": "1.2.2",
    "fallow": "3.5.0",
    "jsdom": "26.1.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.73.0",
    "tailwindcss": "4.2.2",
    "typescript": "7.0.2",
    "ultracite": "7.9.4",
    "vitest": "4.1.8",
    "wxt": "0.20.26"
  },
  "packageManager": "pnpm@11.12.0"
}
